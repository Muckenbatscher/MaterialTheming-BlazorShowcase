@page "/"
@using MudBlazor.Utilities

<PageTitle>Material Theming</PageTitle>

<MudColorPicker ShowToolbar="false" ShowAlpha="false" ShowInputs="false" ThrottleInterval="300" DragEffect="true" PickerVariant="PickerVariant.Static" Value="SelectedColor" ValueChanged="OnSelectedColorChanged" />

<MudSelect T="MaterialTheming.Variant" @bind-Value="SelectedVariant">
    @foreach (var variant in _variants)
    {
        <MudSelectItem Value="@variant">@(variant.ToString())</MudSelectItem>
    }
</MudSelect>

<MudCheckBox @bind-Value="DarkMode">Dark Mode</MudCheckBox>

<MudToggleGroup T="ContrastLevel" @bind-Value="Contrast" Outlined="true" Delimiters="true">
    <MudToggleItem Value="@(ContrastLevel.Normal)">Normal (0.0)</MudToggleItem>
    <MudToggleItem Value="@(ContrastLevel.Medium)">Medium (0.5)</MudToggleItem>
    <MudToggleItem Value="@(ContrastLevel.High)">High (1.0)</MudToggleItem>
</MudToggleGroup>

<ThemeDisplay Theme="_theme"/>

    @code {
    private ThemeColors? _theme = ThemeBuilder.CreateFromSourceColor("#512BD4").Build(); // .NET brand color

    private MudColor SelectedColor
    {
        get;
        set
        {
            field = value;
            GenerateTheme();
        }
    } = "#512BD4";

    private async Task OnSelectedColorChanged(MudColor args)
    {
        SelectedColor = args;
    }

    private List<MaterialTheming.Variant> _variants = [
        MaterialTheming.Variant.TonalSpot,
        MaterialTheming.Variant.Neutral,
        MaterialTheming.Variant.Monochrome,
        MaterialTheming.Variant.Vibrant,
        MaterialTheming.Variant.Fidelity,
        MaterialTheming.Variant.Content,
        MaterialTheming.Variant.Rainbow,
        MaterialTheming.Variant.FruitSalad,
        MaterialTheming.Variant.Expressive,
        MaterialTheming.Variant.CMF,
    ];
    private MaterialTheming.Variant SelectedVariant
    {
        get;
        set
        {
            field = value;
            GenerateTheme();
        }
    } = MaterialTheming.Variant.TonalSpot;

    private bool DarkMode 
    { 
        get; 
        set
        {
            field = value;
            GenerateTheme();
        } 
    } = false;

    private ContrastLevel Contrast
    {
        get;
        set
        {
            field = value;
            GenerateTheme();
        }
    } = ContrastLevel.Normal;

    private void GenerateTheme()
    {
        var colorHex = RgbColor.FromRgb(SelectedColor.R, SelectedColor.G, SelectedColor.B);
        var mode = DarkMode ? ThemeMode.Dark : ThemeMode.Light;
        _theme = ThemeBuilder
            .CreateFromSourceColor(colorHex)
            .WithVariant(SelectedVariant)
            .WithMode(mode)
            .WithContrastLevel(Contrast)
            .WithSpecVersion(SpecVersion.Spec2025)
            .Build();
    }
}
