<MudStack Spacing="0">
    <ColorRoleDisplay IsLarge="true" ColorRoleName="@(ColorRoleName)" Background="@(RoleColor)" Foreground="@(OnRoleColor)" />
    <ColorRoleDisplay ColorRoleName="@(OnColorRoleName)" Background="@(OnRoleColor)" Foreground="@(RoleColor)" />
</MudStack>

@code {
    [Parameter]
    public RgbColor RoleColor { get; set; } = RgbColor.FromArgb(0xFFFFFF);
    [Parameter]
    public RgbColor OnRoleColor { get; set; } = RgbColor.FromArgb(0x000000);

    [Parameter]
    public string ColorRoleName { get; set; } = string.Empty;
    [Parameter]
    public string OnColorRoleName { get; set; } = string.Empty;
    
    protected override void OnInitialized()
    {
        if (string.IsNullOrEmpty(OnColorRoleName))
            OnColorRoleName = $"On {ColorRoleName}";
    }
}
