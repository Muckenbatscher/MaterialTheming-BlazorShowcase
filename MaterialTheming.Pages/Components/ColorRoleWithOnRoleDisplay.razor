<MudStack Spacing="0">
    <ColorRoleDisplay 
        ColorRoleName="@(ColorRoleName)"
        Background="ColorRoleColor"
        Foreground="OnColorRoleColor" />
    <ColorRoleDisplay 
        ColorRoleName="@(OnColorRoleName)"
        Background="OnColorRoleColor"
        Foreground="ColorRoleColor" />
</MudStack>

@code {
    [Parameter]
    public RgbColor ColorRoleColor { get; set; } = RgbColor.FromArgb(0xFFFFFF);

    [Parameter]
    public RgbColor OnColorRoleColor { get; set; } = RgbColor.FromArgb(0x000000);

    [Parameter]
    public string ColorRoleName { get; set; } = string.Empty;
    public string OnColorRoleName => $"On{ColorRoleName}";
}
