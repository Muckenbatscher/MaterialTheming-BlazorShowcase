@page "/material-theming"

<PageTitle>Material Theming</PageTitle>

<MudButton Color="_color" Variant="MudBlazor.Variant.Filled" @onclick="GenerateColor">Generate Color</MudButton>

<ColorRoleDisplay ColorRoleName="TestRole" ></ColorRoleDisplay>

@code {
    private Color _color = Color.Primary;

    private readonly Color[] _colors = new Color[]
    {
        Color.Primary,
        Color.Secondary,
        Color.Tertiary,
        Color.Info,
        Color.Success,
        Color.Warning,
        Color.Error
    };

    private void GenerateColor(MouseEventArgs args)
    {
        var index = new Random().Next(0, _colors.Length);
        _color = _colors[index];
    }
}
